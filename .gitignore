# Obsidian 本地窗口布局/会话状态（每台设备不同，不应同步）
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian 缓存
.obsidian/cache/
.obsidian/plugins/*/data.json.bak

# Obsidian 回收站
.trash/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# Windows 快捷方式（指向本地路径，不应同步）
*.lnk

# Claude Code 运行时产物（锁文件、临时工作区等，非笔记内容）
.claude/
_mineru/

# 自命模拟试题（本地自测用，不上传）
模拟试题/
